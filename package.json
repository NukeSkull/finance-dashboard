{
  "name": "finance-dashboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev:web": "pnpm --filter @finance-dashboard/web dev",
    "dev:api": "pnpm --filter @finance-dashboard/api dev",
    "build:web": "pnpm --filter @finance-dashboard/web build",
    "build:api": "pnpm --filter @finance-dashboard/api build",
    "lint": "pnpm -r lint",
    "test:api": "pnpm --filter @finance-dashboard/api test",
    "typecheck": "pnpm build:api && pnpm --filter @finance-dashboard/web typecheck && pnpm --filter @finance-dashboard/shared typecheck"
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  }
}
